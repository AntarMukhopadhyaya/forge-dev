import { drizzle } from "drizzle-orm/{{#eq
  type "postgres"
}}node-postgres{{else}}better-sqlite3{{/eq}}"; import { betterAuth } from "better-auth";

{{#if (eq type "postgres")}}
  import { Pool } from "pg"; const pool = new Pool({ connectionString:
  process.env.DATABASE_URL, }); export const db = drizzle(pool);
{{else}}
  import Database from "better-sqlite3"; const sqlite = new
  Database(process.env.DATABASE_URL); export const db = drizzle(sqlite);
{{/if}}

export const auth = betterAuth();